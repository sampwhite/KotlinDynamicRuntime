#!/usr/bin/env bash
# Launch the backend app -- the launcher's Start.kt (kdn.StartKt) via :launch:run -- on
# http://localhost:7070. Extra arguments pass through to Gradle. Runnable from any directory.
set -euo pipefail
. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_common.sh"

echo "kdr-backend: starting the backend on http://localhost:7070 (:launch:run) ..." >&2
run_gradle :launch:run "$@"
