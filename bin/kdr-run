#!/usr/bin/env bash
# Launch any Kotlin/Java main class from the project's fat jar, passing arguments through -- the basis for
# writing command-line tools in Kotlin instead of shell or python.
#
# Usage:
#   kdr-run [--build|-b] <fully.qualified.MainClass> [args...]
#
# It keeps the fat jar fresh cheaply, without paying Gradle's startup on every call. Using the manifest
# bin/kdr-source-dirs writes (current-source-directories.txt), it rebuilds the jar -- and regenerates the
# manifest alongside it, so the two never drift -- only when:
#   - the jar or the manifest is missing, or --build is given
#   - settings.gradle.kts is newer than the manifest (the project layout may have changed)
#   - any listed source dir / build script is newer than the jar (a recompile is due)
# Otherwise it launches straight away (no Gradle). The manifest is always regenerated by the fresh jar, so a
# change to the generator itself is picked up too.
#
# The launched code's working directory is the deployment root -- two directories above this script
# (bin -> repo -> root); we assume these scripts stay in bin/.
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
root_dir="$(cd "$script_dir/../.." && pwd)"                # up two: the deployment / build root
fat_jar="$script_dir/../launch/build/libs/launch-all.jar"
manifest="$root_dir/current-source-directories.txt"
settings="$root_dir/settings.gradle.kts"
manifest_class="com.dynamicruntime.script.CurrentSourceDirectoriesKt"

force=false
if [ "${1:-}" = "--build" ] || [ "${1:-}" = "-b" ]; then force=true; shift; fi
if [ "$#" -eq 0 ]; then
    echo "usage: kdr-run [--build|-b] <fully.qualified.MainClass> [args...]" >&2
    exit 2
fi
target="$1"

rebuild=false
if [ "$force" = true ]; then rebuild=true; fi
[ -f "$fat_jar" ] || rebuild=true
[ -f "$manifest" ] || rebuild=true
if [ "$rebuild" = false ] && [ "$settings" -nt "$manifest" ]; then rebuild=true; fi

if [ "$rebuild" = false ]; then
    # Any listed source dir or build script newer than the jar means a recompile is due. `find` treats a file
    # argument as a one-item search, so directories and build scripts are checked together, in one call.
    paths=()
    while IFS= read -r line; do
        case "$line" in '' | '#'*) continue ;; esac
        if [ -e "$root_dir/$line" ]; then paths+=("$root_dir/$line"); fi
    done < "$manifest"
    if [ "${#paths[@]}" -gt 0 ]; then
        newer="$(find "${paths[@]}" -type f -newer "$fat_jar" 2>/dev/null || true)"
        [ -n "$newer" ] && rebuild=true
    fi
fi

cd "$root_dir"
if [ "$rebuild" = true ]; then
    echo "kdr-run: rebuilding the fat jar ..." >&2
    ./gradlew :launch:fatJar
    # Bump the jar's mtime so it is the newest artifact even when Gradle found nothing to recompile (a
    # touched-but-unchanged source leaves :launch:fatJar UP-TO-DATE, so Gradle would not advance the jar and
    # the staleness check would trip on every run). The `make`-style fix: touch the target after building.
    touch "$fat_jar"
    # Regenerate the manifest with (and by) the fresh jar, so it never drifts from the code that produced the
    # jar -- unless we're launching the generator itself, in which case the exec below does it (and we avoid
    # recursing through this smart path).
    if [ "$target" != "$manifest_class" ]; then
        echo "kdr-run: regenerating the source-dir manifest ..." >&2
        java -cp "$fat_jar" "$manifest_class"
    fi
fi

exec java -cp "$fat_jar" "$@"
